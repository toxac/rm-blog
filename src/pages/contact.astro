---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact | Alex">
  <h1 class="text-3xl font-bold tracking-tight text-stone-900 mb-2">Contact</h1>
  <p class="text-stone-600 mb-10 text-sm">Drop me a brief line below. I'll get back to you directly.</p>

  <form action="#" method="POST" class="space-y-6">
    <div>
      <label for="name" class="block text-xs font-semibold uppercase tracking-wider text-stone-500 mb-2">Name</label>
      <input type="text" name="name" id="name" required class="w-full rounded-lg border border-stone-200 bg-white px-4 py-2 text-sm text-stone-900 focus:border-stone-500 focus:outline-none focus:ring-1 focus:ring-stone-500 transition-colors" />
    </div>

    <div>
      <label for="email" class="block text-xs font-semibold uppercase tracking-wider text-stone-500 mb-2">Email</label>
      <input type="email" name="email" id="email" required class="w-full rounded-lg border border-stone-200 bg-white px-4 py-2 text-sm text-stone-900 focus:border-stone-500 focus:outline-none focus:ring-1 focus:ring-stone-500 transition-colors" />
    </div>

    <div>
      <label for="message" class="block text-xs font-semibold uppercase tracking-wider text-stone-500 mb-2">Message</label>
      <textarea id="message" name="message" rows="5" required class="w-full rounded-lg border border-stone-200 bg-white px-4 py-2 text-sm text-stone-900 focus:border-stone-500 focus:outline-none focus:ring-1 focus:ring-stone-500 transition-colors"></textarea>
    </div>

    <button type="submit" class="w-full sm:w-auto inline-flex justify-center rounded-lg bg-stone-900 px-5 py-2.5 text-sm font-medium text-white shadow-xs hover:bg-stone-800 focus:outline-none focus:ring-2 focus:ring-stone-500 focus:ring-offset-2 transition-all cursor-pointer">
      Send Message
    </button>
  </form>
</BaseLayout>