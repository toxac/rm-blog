---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";
// Import Astro's optimized image processing engine
import { Image } from "astro:assets";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.data.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout
  title={`${post.data.title} | Blog`}
  description={post.data.description}
  articleDate={post.data.pubDate.toISOString()}
>
  <article>
    <header class="mb-8">
      <time
        datetime={post.data.pubDate.toISOString()}
        class="text-xs font-medium text-stone-400"
      >
        {post.data.pubDate.toLocaleDateString("en-US", { dateStyle: "long" })}
      </time>
      <h1
        class="mt-2 text-3xl font-bold tracking-tight text-stone-900 sm:text-4xl leading-tight"
      >
        {post.data.title}
      </h1>
      <p class="mt-3 text-xs text-stone-500 italic">By {post.data.author}</p>
    </header>

    {
      post.data.heroImage && (
        <div class="mb-10 overflow-hidden rounded-2xl border border-stone-200 shadow-xs">
          <Image
            src={post.data.heroImage}
            alt={`Featured cover artwork for ${post.data.title}`}
            width={1200}
            height={675}
            loading="eager"
            class="w-full aspect-video object-cover hover:scale-[1.01] transition-transform duration-500 ease-out"
          />
        </div>
      )
    }

    <div
      class="prose prose-stone font-sans prose-headings:font-display prose-headings:font-bold prose-a:text-stone-900 hover:prose-a:text-stone-600 max-w-none prose-p:max-w-prose prose-li:max-w-prose leading-relaxed text-stone-800"
    >
      <Content />
    </div>
    <div class="mt-16 pt-8 border-t border-stone-100 max-w-prose">
      <a 
        href="/blog" 
        class="group inline-flex items-center gap-2 text-sm font-medium text-stone-500 hover:text-stone-900 transition-colors duration-200"
      >
        {/* The arrow will shift left seamlessly on hover via Tailwind's group utility */}
        <span class="inline-block transition-transform duration-200 ease-out group-hover:-translate-x-1">
          &larr;
        </span>
        Back to all writing
      </a>
    </div>
  </article>
</BaseLayout>
