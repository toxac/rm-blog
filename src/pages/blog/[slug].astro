---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    // Route now looks up the custom frontmatter slug property
    params: { slug: post.data.slug }, 
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout 
  title={`${post.data.title} | Blog`} 
  description={post.data.description}
  articleDate={post.data.pubDate.toISOString()}
>
  <article>
    <header class="mb-10">
      <time datetime={post.data.pubDate.toISOString()} class="text-xs font-medium text-stone-400">
        {post.data.pubDate.toLocaleDateString('en-US', { dateStyle: 'long' })}
      </time>
      <h1 class="mt-2 text-3xl font-bold tracking-tight text-stone-900 sm:text-4xl leading-tight">
        {post.data.title}
      </h1>
      <p class="mt-3 text-xs text-stone-500 italic">By {post.data.author}</p>
    </header>

    <div class="prose prose-stone prose-headings:font-bold prose-a:text-stone-900 hover:prose-a:text-stone-600 max-w-none leading-relaxed text-stone-800">
      <Content />
    </div>
  </article>
</BaseLayout>